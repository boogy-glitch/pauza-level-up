{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Pauza Level Up",
  "version": "1.0.0",
  "identifier": "com.pauzalevelup.app",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npx vite build",
    "beforeDevCommand": "npx vite --port 3000"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pauza Level Up",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "languages": null,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
