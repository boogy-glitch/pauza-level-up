{
  "name": "pauza-level-up",
  "private": true,
  "version": "1.0.0",
  "description": "Aplicatie educationala pentru pauze scolare incluzive si interactive",
  "author": "Pauza Level Up",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --port=3000",
    "serve": "vite build && vite preview --port=3000 --host=0.0.0.0",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "generate-icons": "node scripts/generate-icons.cjs",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --win",
    "electron:build:all": "vite build && electron-builder --win --mac --linux",
    "installer": "npm run generate-icons && npm run electron:build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "sharp": "^0.34.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
